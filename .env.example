# =============================================================================
# CCaSS Competitor Intelligence Engine — Environment Variables
# =============================================================================
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to version control.
# =============================================================================

# Database (PostgreSQL with pgvector)
# For local dev: use docker-compose.yml Postgres instance
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/ey_ccass?schema=public"
DIRECT_URL="postgresql://postgres:postgres@localhost:5432/ey_ccass?schema=public"

# Redis (for BullMQ job queue)
REDIS_URL="redis://localhost:6379"

# Authentication (NextAuth.js)
# Generate a secret: openssl rand -base64 32
NEXTAUTH_SECRET="your-secret-here-generate-with-openssl-rand"
NEXTAUTH_URL="http://localhost:3000"
# Optional dedicated secret for worker-driven cache revalidation.
# Falls back to AUTH_SECRET/NEXTAUTH_SECRET when omitted.
REVALIDATE_SECRET="your-revalidation-secret"

# Google Gemini API
GEMINI_API_KEY="your-gemini-api-key"

# Email (Resend) — Phase 2
# RESEND_API_KEY="re_your_key_here"
# RESEND_FROM_EMAIL="intelligence@ey-ccass.com"

# Slack Webhooks — Phase 2
# SLACK_WEBHOOK_URL="https://hooks.slack.com/services/..."

# Object Storage (Cloudflare R2 or AWS S3) — Phase 2
# S3_ENDPOINT="https://your-account.r2.cloudflarestorage.com"
# S3_BUCKET="ey-ccass-exports"
# S3_ACCESS_KEY=""
# S3_SECRET_KEY=""
# S3_REGION="auto"

# App Configuration
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_APP_NAME="CCaSS Intelligence Engine"
NODE_ENV="development"

# Default admin user (created by seed script)
ADMIN_EMAIL="admin@ey.com"
ADMIN_PASSWORD="change-this-password"
